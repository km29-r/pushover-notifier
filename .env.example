# Example environment file for the Pushover notifier
#
# Copy this file to `.env` and replace the placeholder values with
# your own. The service will read these variables at startup.

# Pushover configuration
#
# Your personal user key from https://pushover.net. Required.
PUSHOVER_USER="your_user_key_here"

# The API token for the application you create on Pushover. Required.
PUSHOVER_TOKEN="your_app_token_here"

# Secret key used to protect state‑changing endpoints (/start,
# /stop, /mode/*, /test). Choose a long, random string. Required.
CONTROL_KEY="replace_with_a_long_random_string"

# Optional: API key for UptimeRobot. If provided along with
# UPTIMEROBOT_MONITOR_ID, the application will automatically pause
# and resume the specified monitor when notifications are disabled or
# enabled. See https://uptimerobot.com.
UPTIMEROBOT_API_KEY=""

# Optional: The monitor ID to control with the above API key.
UPTIMEROBOT_MONITOR_ID=""

# Path to the SQLite database. Defaults to ./app.db if unset.
# APP_DB="./app.db"

# Port on which to run the Flask server. Defaults to 8080 if unset.
# PORT=8080